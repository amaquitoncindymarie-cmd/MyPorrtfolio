@page "/projects"
@layout MainLayout

<div class="projects-header">
    <h1 class="page-title">Projects</h1>
    <div class="title-underline"></div>
    <p class="header-subtitle">Work in progress — building skills one project at a time</p>
</div>

<div class="projects-container">
    <div class="project-card">
        <div class="project-icon">◈</div>
        <h3>Personal Portfolio</h3>
        <p>A minimalist portfolio website built with Blazor to document my IT journey and showcase my growth as a developer.</p>
        <div class="project-tech">
            <span>Blazor</span>
            <span>C#</span>
            <span>CSS</span>
        </div>
    </div>
    
    <div class="project-card">
        <div class="project-icon">◈</div>
        <h3>Simple Calculator</h3>
        <p>A functional calculator application that performs basic arithmetic operations, built to practice JavaScript logic.</p>
        <div class="project-tech">
            <span>JavaScript</span>
            <span>HTML</span>
            <span>CSS</span>
        </div>
    </div>
    
    <div class="project-card">
        <div class="project-icon">◈</div>
        <h3>Chat Interface</h3>
        <p>A simple messaging interface exploring real-time interactions and frontend design principles.</p>
        <div class="project-tech">
            <span>Work in Progress</span>
        </div>
    </div>
</div>

<div class="projects-footer">
    <p>Simple projects. Honest effort. Slow but steady progress.</p>
</div>